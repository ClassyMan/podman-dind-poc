FROM docker.io/library/ubuntu:24.04

# Podman + rootless runtime deps. Matches the Ubuntu 24.04 apt podman (4.9.x).
# This is exactly the setup a Jenkins agent Docker image would use to offer
# rootless nested containers to test workloads.
RUN apt-get update && apt-get install -y --no-install-recommends \
      podman \
      fuse-overlayfs \
      slirp4netns \
      uidmap \
      dbus-user-session \
      ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# ubuntu:24.04 ships with a pre-existing `ubuntu` user at UID 1000. We just
# add subuid/subgid ranges for it. These ranges must be a subset of the
# *host* user's subuid range (since Docker doesn't use userns-remap by
# default) — 100000:65536 is the Ubuntu default for real user accounts.
RUN echo "ubuntu:100000:65536" > /etc/subuid \
 && echo "ubuntu:100000:65536" > /etc/subgid

# mirror.gcr.io pull-through cache for the nested docker.io/hello-world pull
# (avoids Docker Hub's 100-pull/6h anonymous rate limit).
COPY registries.conf /etc/containers/registries.conf.d/99-docker-mirror.conf

COPY inner-demo.sh /usr/local/bin/inner-demo.sh
RUN chmod +x /usr/local/bin/inner-demo.sh

USER ubuntu
WORKDIR /home/ubuntu
CMD ["/usr/local/bin/inner-demo.sh"]
